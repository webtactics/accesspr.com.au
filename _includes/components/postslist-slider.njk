     <!-- items -->
<div class="client-class">
      {% for post in postslist | reverse %}
    <div>
        
    <div class="homesliderbanner">

{% if post.data.CaseStudy %}
<a href="/clients/our-work/" alt="{{ post.data.title }}" title="{{ post.data.title }}"><img src="https://ik.imagekit.io/webtactics/accesspr{{ post.data.logo }}?tr=w-400,h-300" alt="{{ post.data.title }}" title="{{ post.data.title }}"></a>
{% else %}
<a href="{{ post.url | url }}" alt="{{ post.data.title }}" title="{{ post.data.title }}"><img src="https://ik.imagekit.io/webtactics/accesspr{{ post.data.logo }}?tr=w-400,h-300" alt="{{ post.data.title }}" title="{{ post.data.title }}"></a>
{% endif %}
</div>
    
    </div>
   {% endfor %}
</div>
     <!-- end items -->